# Django Secret Key - generate a strong random key for production
SECRET_KEY=your-secret-key-here-change-in-production

# Debug mode - set to False for production
DEBUG=False

# Allowed hosts - comma-separated list including Railway domains
ALLOWED_HOSTS=localhost,127.0.0.1,.railway.app,.up.railway.app

# Database URL - PostgreSQL (Railway provides this)
DATABASE_URL=
# Format: postgres://username:password@hostname:port/database_name
DATABASE_URL=postgres://postgres:password@railway-host:5432/railway

# Time zone
TIME_ZONE=UTC